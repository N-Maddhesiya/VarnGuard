{
  "manifest_version": 3,
  "name": "VarnGuard",
  "version": "1.0",
  "description": "VarnGuard Extension Scaffold",
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/serviceWorker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/contentScript.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
